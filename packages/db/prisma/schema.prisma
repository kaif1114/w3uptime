generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Validator {
  id           String        @id @default(uuid())
  publicKey    String        @unique
  ip           String
  balance      Int           @default(0)
  monitorTicks monitorTick[]
}

model User {
  id       String    @id @default(uuid())
  comments Comment[]
  monitors Monitor[]
}

model Monitor {
  id                  String        @id @default(uuid())
  name                String
  url                 String
  checkInterval       Int           @default(300)
  timeout             Int           @default(30)
  expectedStatusCodes Int[]         @default([200, 201, 202, 204])
  status              MonitorStatus @default(ACTIVE)
  lastCheckedAt       DateTime?
  createdAt           DateTime      @default(now())
  userId              String
  alerts              Alert[]
  escalation          Escalation?
  incidents           Incident[]
  user                User          @relation(fields: [userId], references: [id])
  monitorTicks        monitorTick[]
}

model monitorTick {
  id          String            @id @default(uuid())
  monitorId   String
  validatorId String
  status      MonitorTickStatus
  latency     Float
  createdAt   DateTime          @default(now())
  monitor     Monitor           @relation(fields: [monitorId], references: [id])
  validator   Validator         @relation(fields: [validatorId], references: [id])
}

model Escalation {
  id        String            @id @default(uuid())
  monitorId String            @unique
  name      String
  enabled   Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  monitor   Monitor           @relation(fields: [monitorId], references: [id])
  levels    EscalationLevel[]
}

model EscalationLevel {
  id             String            @id @default(uuid())
  escalationId   String
  levelOrder     Int
  waitMinutes    Int
  channel        EscalationChannel @default(EMAIL)
  contacts       String[]
  message        String?
  webhookMethod  String?           @default("POST")
  webhookHeaders Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  escalation     Escalation        @relation(fields: [escalationId], references: [id])

  @@unique([escalationId, levelOrder])
  @@index([escalationId, levelOrder])
}

model Alert {
  id                     String        @id @default(uuid())
  severity               AlertSeverity @default(MEDIUM)
  title                  String
  message                String
  triggerStatusCode      Int?
  expectedStatusCode     Int?
  status                 AlertStatus   @default(PENDING)
  triggeredAt            DateTime      @default(now())
  acknowledgedAt         DateTime?
  acknowledgedBy         String?
  currentEscalationLevel Int           @default(1)
  escalationCompleted    Boolean       @default(false)
  monitorId              String
  monitor                Monitor       @relation(fields: [monitorId], references: [id])
}

model Incident {
  id           String           @id @default(uuid())
  title        String
  description  String?
  severity     IncidentSeverity @default(MINOR)
  status       IncidentStatus   @default(INVESTIGATING)
  monitorId    String          @map("monitor_id")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  resolvedAt   DateTime?
  downtime     Int?
  escalated    Boolean          @default(false)
  postmortemId String?          @unique
  comments     Comment[]
  monitor      Monitor          @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  postmortem   Postmortem?

  @@index([monitorId])
}

model Comment {
  id          String   @id @default(uuid())
  description String
  incidentId  String
  userId      String
  createdAt   DateTime @default(now())
  incident    Incident @relation(fields: [incidentId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Postmortem {
  id             String   @id @default(uuid())
  resolutionTime Int
  rootCause      String
  resolution     String
  incidentId     String   @unique
  createdAt      DateTime @default(now())
  incident       Incident @relation(fields: [incidentId], references: [id])
}

enum MonitorStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  RESOLVED
}

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
  POSTMORTEM
}

enum IncidentSeverity {
  CRITICAL
  MAJOR
  MINOR
  MAINTENANCE
}

enum EscalationChannel {
  EMAIL
  SLACK
  WEBHOOK
}

enum MonitorTickStatus {
  GOOD
  BAD
}
