# ------------------------------------------------------------------
# W3Uptime production env template
# Copy to `.env` on the EC2 host and fill in real values.
# This file is read by `docker-compose.prod.yml` — all variables below
# are available to every service that lists `env_file: .env`.
# ------------------------------------------------------------------

# ---------- TimescaleDB ----------
# Docker initialises the DB with these on first boot.
# After that, changes here have no effect unless you recreate the volume.
POSTGRES_DB=w3uptime
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password

# DATABASE_URL is composed inside compose, but the frontend Next.js standalone
# build reads it as a single string; keep it in sync with the POSTGRES_* vars.
DATABASE_URL=postgresql://postgres:change-me-to-a-strong-password@timescaledb:5432/w3uptime

# ---------- Docker image tags (set by CI/CD) ----------
# GitHub Actions overrides these with ghcr.io/<org>/w3uptime-<service>:<sha>.
# Leave default for a local `docker compose build` workflow.
FRONTEND_IMAGE=w3uptime-frontend:latest
HUB_IMAGE=w3uptime-hub:latest
DATA_INGESTION_IMAGE=w3uptime-data-ingestion:latest
VALIDATOR_IMAGE=w3uptime-validator:latest

# ---------- Persistent demo validator (runs on EC2 to populate global-network) ----------
# Any Ethereum private key (no mainnet funds needed — Sepolia only for testing).
# Generate one with: node -e "const {ethers}=require('ethers');console.log(ethers.Wallet.createRandom().privateKey)"
VALIDATOR_PRIVATE_KEY=0xYOUR_VALIDATOR_PRIVATE_KEY
# Strong password used to encrypt the keystore on first boot (min 8 chars).
VALIDATOR_WALLET_PASSWORD=change-me-to-a-strong-password

# ---------- Frontend: Web3 / Sepolia ----------
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_GOVERNANCE_CONTRACT_ADDRESS=0xe74cedb2ec8ca7607f95297e938078e4ebae304f
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY
AUTHORIZED_SIGNER_KEY=YOUR_AUTHORIZED_SIGNER_PRIVATE_KEY
PLATFORM_SIGNER_ADDRESS=0xYOUR_PLATFORM_SIGNER_ADDRESS
ENABLE_AUTO_FINALIZATION=true
FINALIZATION_INTERVAL_MS=900000

# ---------- Frontend: public URL ----------
# Set to the EC2 public DNS (http://ec2-xx-xx-xx-xx.compute.amazonaws.com)
# or your custom domain once you attach one.
NEXT_PUBLIC_URL=http://your-ec2-public-dns

# ---------- Frontend: Mapbox ----------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN

# ---------- Frontend: sessions ----------
SESSION_EXPIRY_DAYS=7

# ---------- Frontend: Slack integration ----------
SLACK_BOT_TOKEN=xoxb-YOUR-SLACK-BOT-TOKEN
SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
NEXT_PUBLIC_SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
SLACK_REDIRECT_URI=http://your-ec2-public-dns/slack/callback

# ---------- Frontend: email alerts (Gmail SMTP) ----------
GOOGLE_APP_USER=your-gmail@gmail.com
GOOGLE_APP_PASSWORD=your-gmail-app-password

# ---------- Frontend: AI assistant ----------
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-5
CHAT_RATE_LIMIT_PER_MINUTE=20
CHAT_HISTORY_TTL_DAYS=1

# ---------- Frontend: Redis (BullMQ escalation worker) ----------
# REDIS_HOST / REDIS_PORT are hard-coded in docker-compose.prod.yml to
# the compose service name; no need to set them here.

# ---------- Hub: geo lookups ----------
ABSTRACTAPI_KEY=YOUR_ABSTRACT_GEO_API_KEY

# ---------- Hub + data-ingestion service URLs ----------
# Hard-coded in docker-compose.prod.yml to compose service names.
# FRONTEND_URL, HUB_URL, DATA_INGESTION_URL are overridden inside compose.
