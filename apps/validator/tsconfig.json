{
    "compilerOptions": {
      "rootDir": ".",
      "outDir": "build",
      "esModuleInterop": true,
      "module": "ES2022",
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "lib": ["es2022"],
      "target": "es2022",
      "skipLibCheck": true,
      "strict": true,
      "noImplicitAny": true,
      "strictNullChecks": true,
      },
    "include": [
      "src/**/*.ts",
      "test/**/*.ts"
    ]
  } 