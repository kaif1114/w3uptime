# This Dockerfile is optimized for building ONLY the hub service in a turborepo environment
# It uses turbo prune to include only necessary dependencies

FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Enable corepack for package manager management
RUN corepack enable

# Prune the monorepo to only include hub and its dependencies
FROM base AS pruner
RUN npm install -g turbo
COPY . .
RUN turbo prune hub --docker

# Install dependencies for building
FROM base AS deps
# Copy pruned package files (only hub + its workspace deps)
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/package-lock.json ./package-lock.json

# Install all dependencies needed for building
RUN npm ci

# Build the application
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules

# Copy source code (only what's needed for hub)
COPY --from=pruner /app/out/full/ .

# Generate Prisma client (needed by db package)
RUN npx prisma generate --schema=./packages/db/prisma/schema.prisma

# Build the hub app using turbo
RUN npx turbo run build --filter=hub

# Production image
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production

# Create a non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nodeapp

# Copy the built application
COPY --from=builder --chown=nodeapp:nodejs /app/apps/hub/build ./apps/hub/build
COPY --from=builder --chown=nodeapp:nodejs /app/apps/hub/package.json ./apps/hub/

# Copy workspace packages that are needed at runtime (only what turbo prune included)
COPY --from=builder --chown=nodeapp:nodejs /app/packages ./packages/

# Install only production dependencies for runtime (from pruned dependencies)
COPY --from=deps /app/package.json ./package.json
COPY --from=deps /app/package-lock.json ./package-lock.json
RUN npm ci --only=production --omit=dev

USER nodeapp

EXPOSE 8080
ENV PORT=8080

# Run the application
CMD ["node", "apps/hub/build/src/main.js"]
