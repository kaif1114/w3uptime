{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "build",
    "esModuleInterop": true,
    "module": "commonjs",
    "resolveJsonModule": true,
    "lib": ["es2022"],
    "target": "es2022",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
, "config.ts"  ]
} 