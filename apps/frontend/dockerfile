# This Dockerfile is optimized for building ONLY the Next.js frontend app in a turborepo environment
# It uses multi-stage builds and selective copying to minimize image size

FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Enable corepack for package manager management
RUN corepack enable

# Prune the monorepo to only include frontend and its dependencies
FROM base AS pruner
RUN npm install -g turbo
COPY . .
RUN turbo prune frontend --docker

# Install dependencies only when needed
FROM base AS installer
# Copy root package.json and lockfile
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/package-lock.json ./package-lock.json

# Install dependencies for frontend and its workspace dependencies only
RUN npm ci --only=production --omit=dev

# Install all dependencies (including dev dependencies) for building
FROM base AS build-deps
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/package-lock.json ./package-lock.json
RUN npm ci

# Build the application
FROM base AS builder
WORKDIR /app
COPY --from=build-deps /app/node_modules ./node_modules

# Copy source code (only what's needed for frontend)
COPY --from=pruner /app/out/full/ .

# Generate Prisma client
RUN npx prisma generate --schema=./packages/db/prisma/schema.prisma

# Build only the frontend app using turbo
RUN npx turbo run build --filter=frontend

# Production image, copy all the files and run next
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
# Disable Next.js telemetry
ENV NEXT_TELEMETRY_DISABLED=1

# Create a non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copy the built application
COPY --from=builder /app/apps/frontend/public ./apps/frontend/public

# Set the correct permission for prerender cache
RUN mkdir -p ./apps/frontend/.next
RUN chown nextjs:nodejs ./apps/frontend/.next

# Copy the standalone Next.js application
COPY --from=builder --chown=nextjs:nodejs /app/apps/frontend/.next/standalone/ ./
# Copy the static files to the correct location  
COPY --from=builder --chown=nextjs:nodejs /app/apps/frontend/.next/static ./apps/frontend/.next/static
# Copy node_modules from the build-deps stage (which has all dependencies)
COPY --from=build-deps --chown=nextjs:nodejs /app/node_modules ./node_modules

USER nextjs

EXPOSE 8000
ENV PORT=8000
ENV HOSTNAME="0.0.0.0"

# Run the application
# server.js is directly in /app after copying standalone output
CMD ["node", "server.js"]
