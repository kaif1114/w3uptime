# This Dockerfile is optimized for building ONLY the Next.js frontend app in a turborepo environment
# It leverages Next.js standalone mode for automatic dependency optimization

FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Enable corepack for package manager management
RUN corepack enable

# Install dependencies for building
FROM base AS deps
# Copy package files for ALL workspaces so `npm ci` replays the lockfile exactly.
# Omitting any workspace causes npm to fall back to a resolver that can silently
# misplace packages (e.g. un-hoisting zod), which breaks Next.js webpack
# resolution for peer-imported modules like @hookform/resolvers/zod.
COPY package.json package-lock.json* ./
COPY apps/frontend/package.json       ./apps/frontend/
COPY apps/hub/package.json            ./apps/hub/
COPY apps/data-ingestion/package.json ./apps/data-ingestion/
COPY apps/validator/package.json      ./apps/validator/
COPY packages/db/package.json               ./packages/db/
COPY packages/common/package.json           ./packages/common/
COPY packages/eslint-config/package.json    ./packages/eslint-config/
COPY packages/typescript-config/package.json ./packages/typescript-config/
COPY packages/ui/package.json               ./packages/ui/

# Install all dependencies needed for building
RUN npm ci

# Build the application
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
# Workspace-local node_modules (npm doesn't always hoist every package — zod, etc.)
COPY --from=deps /app/apps/frontend/node_modules ./apps/frontend/node_modules

# Copy all source code
COPY . .

# Generate Prisma client
RUN npx prisma generate --schema=./packages/db/prisma/schema.prisma

# NEXT_PUBLIC_* vars must be available at build time — Next.js inlines them
# into the client bundle. Source .env files are gitignored, so CI passes
# these via --build-arg. We write them into apps/frontend/.env.production
# before `next build`, because writing a file invalidates the layer cache
# when a value changes; setting ENV alone does not reliably do that under
# BuildKit.
ARG NEXT_PUBLIC_URL
ARG NEXT_PUBLIC_MAPBOX_TOKEN
ARG NEXT_PUBLIC_CHAIN_ID
ARG NEXT_PUBLIC_GOVERNANCE_CONTRACT_ADDRESS
ARG NEXT_PUBLIC_SLACK_CLIENT_ID
RUN printf '%s\n' \
    "NEXT_PUBLIC_URL=${NEXT_PUBLIC_URL}" \
    "NEXT_PUBLIC_MAPBOX_TOKEN=${NEXT_PUBLIC_MAPBOX_TOKEN}" \
    "NEXT_PUBLIC_CHAIN_ID=${NEXT_PUBLIC_CHAIN_ID}" \
    "NEXT_PUBLIC_GOVERNANCE_CONTRACT_ADDRESS=${NEXT_PUBLIC_GOVERNANCE_CONTRACT_ADDRESS}" \
    "NEXT_PUBLIC_SLACK_CLIENT_ID=${NEXT_PUBLIC_SLACK_CLIENT_ID}" \
    > apps/frontend/.env.production

# Build the frontend app - this creates the optimized standalone build
RUN npm run build --workspace=frontend

# Production image, copy all the files and run next
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
# Disable Next.js telemetry
ENV NEXT_TELEMETRY_DISABLED=1

# Create a non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copy the built application
COPY --from=builder /app/apps/frontend/public ./apps/frontend/public

# Set the correct permission for prerender cache
RUN mkdir -p ./apps/frontend/.next
RUN chown nextjs:nodejs ./apps/frontend/.next

# Copy the standalone Next.js application (includes optimized node_modules automatically)
COPY --from=builder --chown=nextjs:nodejs /app/apps/frontend/.next/standalone/ ./
# Copy the static files to the correct location  
COPY --from=builder --chown=nextjs:nodejs /app/apps/frontend/.next/static ./apps/frontend/.next/static

USER nextjs

EXPOSE 8000
ENV PORT=8000
ENV HOSTNAME="0.0.0.0"

# Run the application
# server.js is located at /app/apps/frontend/server.js
CMD ["node", "apps/frontend/server.js"]
