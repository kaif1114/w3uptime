{
  "info": {
    "name": "W3Uptime - Escalation Policies API",
    "description": "Test collection for escalation policies API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Test Endpoints (No Auth)",
      "item": [
        {
          "name": "GET All Test Policies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/escalation-policies/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "escalation-policies", "test"]
            }
          },
          "response": []
        },
        {
          "name": "CREATE Test Policy - Critical Production",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Critical Production Alerts\",\n  \"levels\": [\n    {\n      \"method\": \"email\",\n      \"target\": \"oncall@company.com\",\n      \"waitTimeMinutes\": 15\n    },\n    {\n      \"method\": \"slack\",\n      \"target\": \"#critical-alerts\",\n      \"waitTimeMinutes\": 30\n    },\n    {\n      \"method\": \"webhook\",\n      \"target\": \"https://webhook.example.com/escalation\",\n      \"waitTimeMinutes\": 0\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/escalation-policies/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "escalation-policies", "test"]
            }
          },
          "response": []
        },
